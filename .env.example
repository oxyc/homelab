# Copy to docker/.env and fill in. Real values live in the Bitwarden note `homelab-env`.
#   bw get notes homelab-env > docker/.env

# --- Cameras (LAN IPs + creds; password MUST be simple alphanumeric for Reolink) ---
FRIGATE_CX820_IP=192.168.x.x
FRIGATE_DOORBELL_IP=192.168.x.x
FRIGATE_CAM_USER=admin
FRIGATE_CAM_PASS=changeme

# --- Frigate ---
FRIGATE_RTSP_PASSWORD=changeme        # go2rtc restream auth
FRIGATE_MQTT_HOST=192.168.x.x         # HA Mosquitto add-on
FRIGATE_MQTT_USER=frigate
FRIGATE_MQTT_PASSWORD=changeme

# --- Image versions (pin for reproducibility; defaults used if unset) ---
FRIGATE_VERSION=stable
SCRYPTED_VERSION=latest
CADDY_VERSION=2

# --- Caddy / HTTPS (wildcard *.{CADDY_LOCAL_DOMAIN} via Cloudflare DNS-01) ---
CADDY_LOCAL_DOMAIN=h.example.com       # your homelab subdomain (real value stays in .env)
ACME_EMAIL=you@example.com
CLOUDFLARE_API_TOKEN=changeme          # scoped: Zone:DNS:Edit on your zone only (Bitwarden)
HAOS_IP=192.168.x.x                    # Home Assistant VM  -> ha.<domain>
PROXMOX_IP=192.168.x.x                 # Proxmox host       -> pve.<domain> (also <host>:8006)
SCRYPTED_HOST=192.168.x.x              # Docker LXC IP      -> scrypted.<domain> (homekit only)
# CLOUDFLARE_API_TOKEN=...             # only if using DNS-01 for real certs

# --- restic / Backblaze B2 ---
RESTIC_REPOSITORY=b2:your-bucket:homelab
RESTIC_PASSWORD=changeme              # client-side encryption key (KEEP THIS in Bitwarden)
B2_ACCOUNT_ID=changeme                # scoped application keyID
B2_ACCOUNT_KEY=changeme               # scoped application key
