extends: default
rules:
  line-length: disable
  comments:
    min-spaces-from-content: 1
  comments-indentation: disable
  document-start: disable
  truthy:
    allowed-values: ["true", "false"]
    check-keys: false
  braces:
    # Frigate uses {FRIGATE_*} placeholders inside quoted strings
    forbid: false
ignore: |
  ansible/roles/*/tasks/main.yml
