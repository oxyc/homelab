# Optional unattended Proxmox install (PVE 8.2+).
# Bake into the ISO:  proxmox-auto-install-assistant prepare-iso proxmox-ve.iso \
#   --fetch-from iso --answer-file answer.toml
# Then boot the prepared USB — installs hands-off to the SSD.

[global]
keyboard = "en-us"
country = "uy"
fqdn = "pve.h.oxy.fi"
mailto = "you@oxy.fi"
timezone = "America/Montevideo"
# Use a HASHED password ($6$… — generate per docs/runbook). The SAME plaintext also goes in
# docker/.env as PVE_PASSWORD (for the Ansible PVE-API auth). Set ONE of the two below:
# root_password = "CHANGE_ME"
root_password_hashed = "CHANGE_ME"

[network]
source = "from-dhcp"

[disk-setup]
filesystem = "ext4"                  # NOT zfs (see decisions.md D5)
disk_list = ["sda"]                  # the 512GB SSD; 2TB NVMe is added later by ansible
