# Local HTTPS reverse proxy. Naming scheme (see docs/dns.md):
#   *.home  -> this Caddy (one Omada DNS record: *.home -> docker-lxc IP); Caddy fans out.
#   Works on LAN and over Tailscale (split-DNS for `home`).
#   Proxmox is NOT here — reach it directly as https://pve:8006 (Tailscale MagicDNS node).
# Default: Caddy's internal CA (trust the root once on your devices).
# For real certs on *.home, use a DNS-01 challenge with {env.CLOUDFLARE_API_TOKEN}.

{
	# email you@example.com          # uncomment + DNS challenge for public certs
}

frigate.{$CADDY_LOCAL_DOMAIN} {
	tls internal
	reverse_proxy frigate:5000
}

scrypted.{$CADDY_LOCAL_DOMAIN} {
	tls internal
	reverse_proxy https://127.0.0.1:10443 {   # Scrypted is host-networked + self-signed
		transport http {
			tls_insecure_skip_verify
		}
	}
}

ha.{$CADDY_LOCAL_DOMAIN} {
	tls internal
	reverse_proxy <haos-vm-ip>:8123
}
